  void _showFullInfoDialog(AppThemeData theme) {
    // State variables declared outside builder to persist across rebuilds
    bool isEditMode = false;
    String? emergencyProvinceCode;
    String? emergencyCityCode;
    String? emergencyBarangayCode;
    // Flags to prevent initial load from overwriting user selections
    bool hasInitiallyLoadedEmergencyAddress = false;
    
    // Reset patient address instance variables and load from database
    _dialogProvinceCode = null;
    _dialogCityCode = null;
    _dialogBarangayCode = null;
    _dialogAddressLoaded = false;
    
    showDialog(
      context: context,
      barrierDismissible: false,
      builder: (BuildContext context) {
        return StatefulBuilder(
          builder: (context, setState) {
            // Load patient address codes from database (only once)
            if (!_dialogAddressLoaded && _patient?.province != null && _patient!.province!.isNotEmpty) {
              _dialogAddressLoaded = true;
              WidgetsBinding.instance.addPostFrameCallback((_) async {
                print('DEBUG: Loading patient address codes from DB');
                await _loadAddressCodesFromDatabase(
                  setState,
                  (code) { 
                    if (_dialogProvinceCode == null) {
                      _dialogProvinceCode = code;
                      print('DEBUG: Set _dialogProvinceCode from DB: $code');
                    }
                  },
                  (code) { if (_dialogCityCode == null) _dialogCityCode = code; },
                  (code) { if (_dialogBarangayCode == null) _dialogBarangayCode = code; },
                );
              });
            }
            
            // Load emergency contact address codes only
            if (!hasInitiallyLoadedEmergencyAddress && _patient?.emergencyContact?.province != null) {
              hasInitiallyLoadedEmergencyAddress = true;
              WidgetsBinding.instance.addPostFrameCallback((_) async {
                await _loadEmergencyContactAddressCodesFromDatabase(
                  setState,
                  (code) => emergencyProvinceCode = code,
                  (code) => emergencyCityCode = code,
                  (code) => emergencyBarangayCode = code,
                );
              });
            }
            return Dialog(
              shape: RoundedRectangleBorder(
                borderRadius: BorderRadius.circular(16),
              ),
              child: Container(
                constraints: BoxConstraints(
                  maxWidth: 800,
                  maxHeight: MediaQuery.of(context).size.height * 0.9,
                ),
                child: Column(
                  children: [
                    Container(
                      padding: const EdgeInsets.all(20),
                      decoration: BoxDecoration(
                        gradient: LinearGradient(
                          colors: [
                            theme.buttonPrimary,
                            theme.buttonPrimary.withOpacity(0.85),
                          ],
                          begin: Alignment.topLeft,
                          end: Alignment.bottomRight,
                        ),
                        borderRadius: const BorderRadius.only(
                          topLeft: Radius.circular(16),
                          topRight: Radius.circular(16),
                        ),
                      ),
                      child: Row(
                        mainAxisAlignment: MainAxisAlignment.spaceBetween,
                        children: [
                          Text(
                            'Patient Information',
                            style: const TextStyle(
                              fontSize: 18,
                              fontWeight: FontWeight.w800,
                              color: Colors.white,
                            ),
                          ),
                          Row(
                            children: [
                              if (!isEditMode)
                                IconButton(
                                  icon: const Icon(Icons.edit),
                                  color: Colors.white,
                                  onPressed: () {
                                    setState(() {
                                      isEditMode = true;
                                    });
                                  },
                                  tooltip: 'Edit',
                                  splashRadius: 24,
                                ),
                              if (!isEditMode)
                                const SizedBox(width: 12),
                              IconButton(
                                icon: const Icon(Icons.close),
                                color: Colors.white,
                                onPressed: () => Navigator.of(context).pop(),
                                tooltip: 'Close',
                                splashRadius: 24,
                              ),
                            ],
                          ),
                        ],
                      ),
                    ),
                    // Content
                    Expanded(
                      child: SingleChildScrollView(
                        child: Padding(
                          padding: const EdgeInsets.all(24),
                          child: _buildPersonalInfoTab(
                            theme,
                            isEditMode: isEditMode,
                            selectedProvinceCode: _dialogProvinceCode,
                            selectedCityCode: _dialogCityCode,
                            selectedBarangayCode: _dialogBarangayCode,
                            onProvinceChanged: (code) {
                              setState(() {
                                _dialogProvinceCode = code;
                                print('DEBUG: _dialogProvinceCode updated to: $code');
                              });
                            },
                            onCityChanged: (code) {
                              setState(() {
                                _dialogCityCode = code;
                              });
                            },
                            onBarangayChanged: (code) {
                              setState(() {
                                _dialogBarangayCode = code;
                              });
                            },
                            emergencyProvinceCode: emergencyProvinceCode,
                            emergencyCityCode: emergencyCityCode,
                            emergencyBarangayCode: emergencyBarangayCode,
                            onEmergencyProvinceChanged: (code) {
                              setState(() {
                                emergencyProvinceCode = code;
                              });
                            },
                            onEmergencyCityChanged: (code) {
                              setState(() {
                                emergencyCityCode = code;
                              });
                            },
                            onEmergencyBarangayChanged: (code) {
                              setState(() {
                                emergencyBarangayCode = code;
                              });
                            },
                          ),
                        ),
                      ),
                    ),
                    // Save/Cancel buttons in edit mode
                    if (isEditMode)
                      Container(
                        padding: const EdgeInsets.all(16),
                        decoration: BoxDecoration(
                          border: Border(
                            top: BorderSide(
                              color: theme.buttonPrimary.withOpacity(0.2),
                              width: 1,
                            ),
                          ),
                        ),
                        child: Row(
                          mainAxisAlignment: MainAxisAlignment.end,
                          children: [
                            TextButton(
                              onPressed: () {
                                setState(() {
                                  isEditMode = false;
                                });
                              },
                              child: Text(
                                'Cancel',
                                style: TextStyle(
                                  color: Colors.grey[600],
                                  fontWeight: FontWeight.w600,
                                ),
                              ),
                            ),
                            const SizedBox(width: 12),
                            ElevatedButton(
                              onPressed: () {
                                // Collect edited data from form fields
                                _savePatientChanges(
                                  context,
                                  theme,
                                  lastName: _fieldControllers['lastName']?.text ?? _patient!.lastName,
                                  firstName: _fieldControllers['firstName']?.text ?? _patient!.firstName,
                                  middleName: _fieldControllers['middleName']?.text ?? _patient!.middleName,
                                  extension: _fieldControllers['extension']?.text ?? _patient!.extension,
                                  birthDate: _editingBirthDate ?? _patient!.birthDate,
                                  contactNumber: _fieldControllers['contactNumber']?.text ?? _patient!.contactNumber,
                                  civilStatus: _fieldControllers['civilStatus']?.text ?? _patient!.civilStatus,
                                  religion: _fieldControllers['religion']?.text ?? _patient!.religion,
                                  purok: _fieldControllers['purok']?.text ?? _patient!.purok,
                                  provinceCode: _dialogProvinceCode ?? _patient!.province,
                                  cityCode: _dialogCityCode ?? _patient!.cityMunicipal,
                                  barangayCode: _dialogBarangayCode ?? _patient!.barangay,
                                  emergencyContactName: _fieldControllers['emergencyContactName']?.text ?? _patient!.emergencyContact?.name,
                                  emergencyContactRelationship: _fieldControllers['emergencyContactRelationship']?.text ?? _patient!.emergencyContact?.relationship,
                                  emergencyContactNumber: _fieldControllers['emergencyContactNumber']?.text ?? _patient!.emergencyContact?.contactNumber,
                                  emergencyContactPurok: _fieldControllers['emergencyContactPurok']?.text ?? _patient!.emergencyContact?.purok,
                                  emergencyProvinceCode: emergencyProvinceCode ?? _patient!.emergencyContact?.province,
                                  emergencyCityCode: emergencyCityCode ?? _patient!.emergencyContact?.cityMunicipal,
                                  emergencyBarangayCode: emergencyBarangayCode ?? _patient!.emergencyContact?.barangay,
                                );
                                print('DEBUG SAVE: _dialogProvinceCode=$_dialogProvinceCode, patient.province=${_patient!.province}');
                                print('DEBUG SAVE: Using provinceCode: ${_dialogProvinceCode ?? _patient!.province}');
                              },
                              style: ElevatedButton.styleFrom(
                                backgroundColor: theme.buttonPrimary,
                                padding: const EdgeInsets.symmetric(
                                  horizontal: 24,
                                  vertical: 12,
                                ),
                              ),
                              child: const Text(
                                'Save Changes',
                                style: TextStyle(
                                  color: Colors.white,
                                  fontWeight: FontWeight.w600,
                                ),
                              ),
                            ),
                          ],
                        ),
                      ),
                  ],
                ),
              ),
            );
          },
        );
      },
    );
  }

  Widget _buildPersonalInfoTab(
    AppThemeData theme, {
    bool isEditMode = false,
    String? selectedProvinceCode,
    String? selectedCityCode,
    String? selectedBarangayCode,
    Function(String?)? onProvinceChanged,
    Function(String?)? onCityChanged,
    Function(String?)? onBarangayChanged,
    String? emergencyProvinceCode,
    String? emergencyCityCode,
    String? emergencyBarangayCode,
    Function(String?)? onEmergencyProvinceChanged,
    Function(String?)? onEmergencyCityChanged,
    Function(String?)? onEmergencyBarangayChanged,
  }) {
    return Column(
      crossAxisAlignment: CrossAxisAlignment.start,
      children: [
        // Profile Picture - Clickable to view full photo
        Center(
          child: GestureDetector(
            onTap: _patient!.photoUrl != null && _patient!.photoUrl!.isNotEmpty
                ? () {
                    Navigator.push(
                      context,
                      MaterialPageRoute(
                        builder: (context) => PhotoViewerWidget(
                          photoUrl: _patient!.photoUrl!,
                          userName: _patient!.fullName,
                        ),
                      ),
                    );
                  }
                : null,
            child: Container(
              width: 120,
              height: 120,
              decoration: BoxDecoration(
                shape: BoxShape.circle,
                border: Border.all(
                  color: theme.buttonPrimary,
                  width: 3,
                ),
                image: _patient!.photoUrl != null && _patient!.photoUrl!.isNotEmpty
                    ? DecorationImage(
                        image: NetworkImage(_patient!.photoUrl!),
                        fit: BoxFit.cover,
                      )
                    : null,
                color: _patient!.photoUrl == null || _patient!.photoUrl!.isEmpty
                    ? theme.buttonPrimary.withOpacity(0.1)
                    : null,
              ),
              child: _patient!.photoUrl == null || _patient!.photoUrl!.isEmpty
                  ? Center(
                      child: Text(
                        _patient!.initials,
                        style: TextStyle(
                          fontSize: 40,
                          fontWeight: FontWeight.w800,
                          color: theme.buttonPrimary,
                        ),
                      ),
                    )
                  : null,
            ),
          ),
        ),
        const SizedBox(height: 28),
        // Two-column layout for personal info
        if (!isEditMode)
          Row(
            crossAxisAlignment: CrossAxisAlignment.start,
            children: [
              Expanded(
                child: Column(
                  crossAxisAlignment: CrossAxisAlignment.start,
                  children: [
                    _buildFullInfoItem(theme, 'Last Name', _patient!.lastName),
                    const SizedBox(height: 20),
                    _buildFullInfoItem(theme, 'First Name', _patient!.firstName),
                    const SizedBox(height: 20),
                    _buildFullInfoItem(theme, 'Middle Name', _patient!.middleName ?? 'N/A'),
                    const SizedBox(height: 20),
                    _buildFullInfoItem(theme, 'Extension', _patient!.extension ?? 'N/A'),
                    const SizedBox(height: 20),
                    _buildFullInfoItem(theme, 'Hospital ID', _patient!.hospitalId),
                    const SizedBox(height: 20),
                    _buildFullInfoItem(theme, 'Date of Birth', _patient!.birthDate),
                    const SizedBox(height: 20),
                    _buildFullInfoItem(theme, 'Address', _formatAddressWithUppercaseBarangay(_patient!.address)),
                    const SizedBox(height: 20),
                    _buildFullInfoItem(theme, 'Civil Status', _patient!.civilStatus ?? 'Not provided'),
                  ],
                ),
              ),
              const SizedBox(width: 32),
              Expanded(
                child: Column(
                  crossAxisAlignment: CrossAxisAlignment.start,
                  children: [
                    _buildFullInfoItem(theme, 'Age', '${_patient!.age} years old'),
                    const SizedBox(height: 20),
                    _buildFullInfoItem(theme, 'Gender', _patient!.sex),
                    const SizedBox(height: 20),
                    _buildFullInfoItem(theme, 'Contact Number', _patient!.contactNumber ?? 'Not provided'),
                    const SizedBox(height: 20),
                    _buildFullInfoItem(theme, 'Religion', _patient!.religion ?? 'Not provided'),
                  ],
                ),
              ),
            ],
          )
        else
          // Edit mode: Show individual name and address components
          Column(
            crossAxisAlignment: CrossAxisAlignment.start,
            children: [
              // Name Components
              Text(
                'NAME COMPONENTS',
                style: TextStyle(
                  fontSize: 12,
                  fontWeight: FontWeight.w800,
