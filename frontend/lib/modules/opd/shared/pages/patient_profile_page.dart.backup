  Future<void> _savePatientChanges(
    BuildContext context,
    AppThemeData theme, {
    required String lastName,
    required String firstName,
    String? middleName,
    String? extension,
    required String birthDate,
    String? contactNumber,
    String? civilStatus,
    String? religion,
    String? purok,
    String? provinceCode,
    String? cityCode,
    String? barangayCode,
    String? emergencyContactName,
    String? emergencyContactRelationship,
    String? emergencyContactNumber,
    String? emergencyContactPurok,
    String? emergencyProvinceCode,
    String? emergencyCityCode,
    String? emergencyBarangayCode,
  }) async {
    try {
      // Show loading dialog
      showDialog(
        context: context,
        barrierDismissible: false,
        builder: (BuildContext context) {
          return Dialog(
            child: Padding(
              padding: const EdgeInsets.all(24),
              child: Column(
                mainAxisSize: MainAxisSize.min,
                children: [
                  CircularProgressIndicator(color: theme.buttonPrimary),
                  const SizedBox(height: 16),
                  const Text('Saving changes...'),
                ],
              ),
            ),
          );
        },
      );

      // Collect edited data
      final Map<String, dynamic> updateData = {
        'lastname': lastName,
        'firstname': firstName,
        'middlename': middleName,
        'ext': extension,
        'birthdate': birthDate,
        'contact_number': contactNumber,
        'civil_status': civilStatus,
        'religion': religion,
        'purok': purok,
        'province': provinceCode,
        'city_municipal': cityCode,
        'barangay': barangayCode,
        'emergency_contact': {
          'contact_name': emergencyContactName,
          'relationship': emergencyContactRelationship,
          'contact_number': emergencyContactNumber,
          'purok': emergencyContactPurok,
          'province': emergencyProvinceCode,
          'city_municipal': emergencyCityCode,
          'barangay': emergencyBarangayCode,
        }
      };

      // Send to backend API
      final response = await _patientProvider.updatePatient(
        _patient!.hospitalId,
        updateData,
      );

      // Close loading dialog
      if (mounted) Navigator.of(context).pop();

      if (response.statusCode == 200) {
        // Show success message in dialog
        if (mounted) {
          showDialog(
            context: context,
            barrierDismissible: false,
            builder: (BuildContext context) {
              return Dialog(
                shape: RoundedRectangleBorder(
                  borderRadius: BorderRadius.circular(12),
                ),
                child: Padding(
                  padding: const EdgeInsets.all(24),
                  child: Column(
                    mainAxisSize: MainAxisSize.min,
                    children: [
                      Icon(
                        Icons.check_circle,
                        color: Colors.green,
                        size: 48,
                      ),
                      const SizedBox(height: 16),
                      const Text(
                        'Success',
                        style: TextStyle(
                          fontSize: 18,
                          fontWeight: FontWeight.w800,
                        ),
                      ),
                      const SizedBox(height: 8),
                      const Text(
                        'Patient information updated successfully',
                        textAlign: TextAlign.center,
                        style: TextStyle(
                          fontSize: 14,
                          color: Colors.black87,
                        ),
                      ),
                      const SizedBox(height: 24),
                      ElevatedButton(
                        onPressed: () {
                          Navigator.of(context).pop(); // Close success dialog
                          Navigator.of(context).pop(); // Close patient info dialog
                          _loadPatient(); // Reload patient data
                        },
                        style: ElevatedButton.styleFrom(
                          backgroundColor: theme.buttonPrimary,
                          padding: const EdgeInsets.symmetric(
                            horizontal: 32,
                            vertical: 12,
                          ),
                        ),
                        child: const Text(
                          'OK',
                          style: TextStyle(
                            color: Colors.white,
                            fontWeight: FontWeight.w600,
                          ),
                        ),
                      ),
                    ],
                  ),
                ),
              );
            },
          );
        }
      } else {
        // Show error message in dialog
        if (mounted) {
          showDialog(
            context: context,
            barrierDismissible: false,
            builder: (BuildContext context) {
              return Dialog(
                shape: RoundedRectangleBorder(
                  borderRadius: BorderRadius.circular(12),
                ),
                child: Padding(
                  padding: const EdgeInsets.all(24),
                  child: Column(
                    mainAxisSize: MainAxisSize.min,
                    children: [
                      Icon(
                        Icons.error_outline,
                        color: Colors.red,
                        size: 48,
                      ),
                      const SizedBox(height: 16),
                      const Text(
                        'Error',
                        style: TextStyle(
                          fontSize: 18,
                          fontWeight: FontWeight.w800,
                        ),
                      ),
                      const SizedBox(height: 8),
                      Text(
                        'Error saving changes: ${response.statusCode}',
                        textAlign: TextAlign.center,
                        style: const TextStyle(
                          fontSize: 14,
                          color: Colors.black87,
                        ),
                      ),
                      const SizedBox(height: 24),
                      ElevatedButton(
                        onPressed: () {
                          Navigator.of(context).pop(); // Close error dialog
                        },
                        style: ElevatedButton.styleFrom(
                          backgroundColor: Colors.red,
                          padding: const EdgeInsets.symmetric(
                            horizontal: 32,
                            vertical: 12,
                          ),
                        ),
                        child: const Text(
                          'OK',
                          style: TextStyle(
                            color: Colors.white,
                            fontWeight: FontWeight.w600,
                          ),
                        ),
                      ),
                    ],
                  ),
                ),
              );
            },
          );
        }
      }
    } catch (e) {
      // Close loading dialog if still open
      if (mounted && Navigator.of(context).canPop()) {
        Navigator.of(context).pop();
      }

      // Show error message in dialog
      if (mounted) {
        showDialog(
          context: context,
          barrierDismissible: false,
          builder: (BuildContext context) {
            return Dialog(
              shape: RoundedRectangleBorder(
                borderRadius: BorderRadius.circular(12),
              ),
              child: Padding(
                padding: const EdgeInsets.all(24),
                child: Column(
                  mainAxisSize: MainAxisSize.min,
                  children: [
                    Icon(
                      Icons.error_outline,
                      color: Colors.red,
                      size: 48,
                    ),
                    const SizedBox(height: 16),
                    const Text(
                      'Error',
                      style: TextStyle(
                        fontSize: 18,
                        fontWeight: FontWeight.w800,
                      ),
                    ),
                    const SizedBox(height: 8),
                    Text(
                      'Error: $e',
                      textAlign: TextAlign.center,
                      style: const TextStyle(
                        fontSize: 14,
                        color: Colors.black87,
                      ),
                    ),
                    const SizedBox(height: 24),
                    ElevatedButton(
                      onPressed: () {
                        Navigator.of(context).pop();
                      },
                      style: ElevatedButton.styleFrom(
                        backgroundColor: Colors.red,
                        padding: const EdgeInsets.symmetric(
                          horizontal: 32,
                          vertical: 12,
                        ),
                      ),
                      child: const Text(
                        'OK',
                        style: TextStyle(
                          color: Colors.white,
                          fontWeight: FontWeight.w600,
                        ),
                      ),
                    ),
                  ],
                ),
              ),
            );
          },
        );
      }
    }
  }

  Future<void> _loadEmergencyContactAddressCodesFromDatabase(
    StateSetter setState,
    Function(String?) setProvinceCode,
    Function(String?) setCityCode,
    Function(String?) setBarangayCode,
  ) async {
    try {
      final addressService = AddressService();
      
      if (_patient?.emergencyContact?.province != null && _patient!.emergencyContact!.province!.isNotEmpty) {
        final provinces = await addressService.fetchProvinces();
        Province? matchingProvince;
        
        try {
          matchingProvince = provinces.firstWhere(
            (p) => p.name.toUpperCase() == _patient!.emergencyContact!.province!.toUpperCase(),
          );
        } catch (e) {
          matchingProvince = provinces.isNotEmpty ? provinces.first : null;
        }
        
        if (matchingProvince != null) {
          setState(() {
            setProvinceCode(matchingProvince!.code);
          });
          
          if (_patient?.emergencyContact?.cityMunicipal != null && _patient!.emergencyContact!.cityMunicipal!.isNotEmpty) {
            final cities = await addressService.fetchCities(provinceCode: matchingProvince.code);
            City? matchingCity;
            
            try {
              matchingCity = cities.firstWhere(
                (c) => c.name.toUpperCase() == _patient!.emergencyContact!.cityMunicipal!.toUpperCase(),
              );
            } catch (e) {
              matchingCity = cities.isNotEmpty ? cities.first : null;
            }
            
            if (matchingCity != null) {
              setState(() {
                setCityCode(matchingCity!.code);
              });
              
              if (_patient?.emergencyContact?.barangay != null && _patient!.emergencyContact!.barangay!.isNotEmpty) {
                final barangays = await addressService.fetchBarangays(cityCode: matchingCity.code);
                Barangay? matchingBarangay;
                
                try {
                  matchingBarangay = barangays.firstWhere(
                    (b) => b.name.toUpperCase() == _patient!.emergencyContact!.barangay!.toUpperCase(),
                  );
                } catch (e) {
                  matchingBarangay = barangays.isNotEmpty ? barangays.first : null;
                }
                
                if (matchingBarangay != null) {
                  setState(() {
                    setBarangayCode(matchingBarangay!.code);
                  });
                }
              }
            }
          }
        }
      }
    } catch (e) {
      print('Error loading emergency contact address codes: $e');
    }
  }

  Future<Map<String, String?>> _getInitialAddressCodes() async {
    final result = <String, String?>{
      'province': null,
      'city': null,
      'barangay': null,
      'emergencyProvince': null,
      'emergencyCity': null,
      'emergencyBarangay': null,
    };
    
    try {
      final addressService = AddressService();
      
      // Load patient address codes
      if (_patient?.province != null && _patient!.province!.isNotEmpty) {
        final provinces = await addressService.fetchProvinces();
        try {
          final matchingProvince = provinces.firstWhere(
            (p) => p.name.toUpperCase() == _patient!.province!.toUpperCase(),
          );
          result['province'] = matchingProvince.code;
          
          // Load cities
          if (_patient?.cityMunicipal != null && _patient!.cityMunicipal!.isNotEmpty) {
            final cities = await addressService.fetchCities(provinceCode: matchingProvince.code);
            try {
              final matchingCity = cities.firstWhere(
                (c) => c.name.toUpperCase() == _patient!.cityMunicipal!.toUpperCase(),
              );
              result['city'] = matchingCity.code;
              
              // Load barangays
              if (_patient?.barangay != null && _patient!.barangay!.isNotEmpty) {
                final barangays = await addressService.fetchBarangays(cityCode: matchingCity.code);
                try {
                  final matchingBarangay = barangays.firstWhere(
                    (b) => b.name.toUpperCase() == _patient!.barangay!.toUpperCase(),
                  );
                  result['barangay'] = matchingBarangay.code;
                } catch (_) {}
              }
            } catch (_) {}
          }
        } catch (_) {}
      }
      
      // Load emergency contact address codes
      if (_patient?.emergencyContact?.province != null && _patient!.emergencyContact!.province!.isNotEmpty) {
        final provinces = await addressService.fetchProvinces();
        try {
          final matchingProvince = provinces.firstWhere(
            (p) => p.name.toUpperCase() == _patient!.emergencyContact!.province!.toUpperCase(),
          );
          result['emergencyProvince'] = matchingProvince.code;
          
          // Load cities
          if (_patient?.emergencyContact?.cityMunicipal != null && _patient!.emergencyContact!.cityMunicipal!.isNotEmpty) {
            final cities = await addressService.fetchCities(provinceCode: matchingProvince.code);
            try {
              final matchingCity = cities.firstWhere(
                (c) => c.name.toUpperCase() == _patient!.emergencyContact!.cityMunicipal!.toUpperCase(),
              );
              result['emergencyCity'] = matchingCity.code;
              
              // Load barangays
              if (_patient?.emergencyContact?.barangay != null && _patient!.emergencyContact!.barangay!.isNotEmpty) {
                final barangays = await addressService.fetchBarangays(cityCode: matchingCity.code);
                try {
                  final matchingBarangay = barangays.firstWhere(
                    (b) => b.name.toUpperCase() == _patient!.emergencyContact!.barangay!.toUpperCase(),
                  );
                  result['emergencyBarangay'] = matchingBarangay.code;
                } catch (_) {}
              }
            } catch (_) {}
          }
        } catch (_) {}
      }
    } catch (e) {
      print('Error loading initial address codes: $e');
    }
    
    return result;
  }

  Future<void> _loadAddressCodesFromDatabase(
    StateSetter setState,
    Function(String?) setProvinceCode,
    Function(String?) setCityCode,
    Function(String?) setBarangayCode,
  ) async {
    try {
      final addressService = AddressService();
      
      // Load all provinces to find the code for patient's current province
      if (_patient?.province != null && _patient!.province!.isNotEmpty) {
        final provinces = await addressService.fetchProvinces();
        Province? matchingProvince;
        
        try {
          matchingProvince = provinces.firstWhere(
            (p) => p.name.toUpperCase() == _patient!.province!.toUpperCase(),
          );
        } catch (e) {
          // No matching province found
          matchingProvince = provinces.isNotEmpty ? provinces.first : null;
        }
        
        if (matchingProvince != null) {
          setState(() {
            setProvinceCode(matchingProvince!.code);
          });
          
          // Load cities for the selected province
          if (_patient?.cityMunicipal != null && _patient!.cityMunicipal!.isNotEmpty) {
            final cities = await addressService.fetchCities(provinceCode: matchingProvince.code);
            City? matchingCity;
            
            try {
              matchingCity = cities.firstWhere(
                (c) => c.name.toUpperCase() == _patient!.cityMunicipal!.toUpperCase(),
              );
            } catch (e) {
              // No matching city found
              matchingCity = cities.isNotEmpty ? cities.first : null;
            }
            
            if (matchingCity != null) {
              setState(() {
                setCityCode(matchingCity!.code);
              });
              
              // Load barangays for the selected city
              if (_patient?.barangay != null && _patient!.barangay!.isNotEmpty) {
                final barangays = await addressService.fetchBarangays(cityCode: matchingCity.code);
                Barangay? matchingBarangay;
                
                try {
                  matchingBarangay = barangays.firstWhere(
                    (b) => b.name.toUpperCase() == _patient!.barangay!.toUpperCase(),
                  );
                } catch (e) {
                  // No matching barangay found
                  matchingBarangay = barangays.isNotEmpty ? barangays.first : null;
                }
                
                if (matchingBarangay != null) {
                  setState(() {
                    setBarangayCode(matchingBarangay!.code);
                  });
                }
              }
            }
          }
        }
      }
    } catch (e) {
      print('Error loading address codes: $e');
    }
  }

  void _addVisit(BuildContext context) {
    // Use shared OPD route - accessible to all OPD roles
    Navigator.pushNamed(
      context,
      '/opd/add-visit',
      arguments: widget.hospitalId,
    );
  }
}
