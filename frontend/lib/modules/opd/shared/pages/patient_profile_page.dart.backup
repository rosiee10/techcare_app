              Text(
                'ADDRESS COMPONENTS',
                style: TextStyle(
                  fontSize: 12,
                  fontWeight: FontWeight.w800,
                  color: theme.buttonPrimary,
                  letterSpacing: 0.5,
                ),
              ),
              const SizedBox(height: 16),
              // Purok text field (not a dropdown)
              _buildEditableField(theme, 'Purok', _patient!.purok ?? '', 'purok'),
              const SizedBox(height: 20),
              // Province, City, Barangay dropdowns
              // Initialize with null - users select new address during editing
              PhilippineAddressDropdown(
                label: '',
                selectedProvinceCode: selectedProvinceCode,
                selectedCityCode: selectedCityCode,
                selectedBarangayCode: selectedBarangayCode,
                onProvinceChanged: (code, name) {
                  // Handle province change - store for later save
                  print('DEBUG: Province selected - code=$code, name=$name');
                  setState(() {
                    selectedProvinceCode = code;
                    print('DEBUG: selectedProvinceCode updated to: $selectedProvinceCode');
                  });
                  // CRITICAL: Call the callback to update the instance variable
                  onProvinceChanged?.call(code);
                },
                onCityChanged: (code, name) {
                  // Handle city change - store for later save
                  setState(() {
                    selectedCityCode = code;
                  });
                  // CRITICAL: Call the callback to update the instance variable
                  onCityChanged?.call(code);
                },
                onBarangayChanged: (code, name) {
                  // Handle barangay change - store for later save
                  setState(() {
                    selectedBarangayCode = code;
                  });
                  // CRITICAL: Call the callback to update the instance variable
                  onBarangayChanged?.call(code);
                },
                showRegion: false,
                showProvince: true,
                showCity: true,
                showBarangay: true,
              ),
            ],
          ),
        const SizedBox(height: 32),
        // Emergency Contact Section
        Text(
          'EMERGENCY CONTACT',
          style: TextStyle(
            fontSize: 12,
            fontWeight: FontWeight.w800,
